": 8.2}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2926807379.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2926807379.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37066636", "episodes_info": "", "photos": ["https://img9.doubanio.com/view/photo/m/public/p2926810095.jpg", "https://img3.doubanio.com/view/photo/m/public/p2926810093.jpg", "https://img9.doubanio.com/view/photo/m/public/p2929006786.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931010036.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 动画 / 平牧大辅 / 大冢刚央 伊驹百合绘", "title": "【我推的孩子】 第三季", "type": "tv", "id": "37066636", "tags": []}, {"comment": "主角大狼十三自小被组织捡养，并成为传说级杀手。某次任务中，他遭到神秘生物兵器刺中，竟意外变回中学生的模样，从此开始了国中生活……", "rating": {"count": 0, "max": 10, "star_count": 0.0, "value": 0}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2928289698.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2928289698.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37315515", "episodes_info": "", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2931037983.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931037982.jpg", "https://img2.doubanio.com/view/photo/m/public/p2931037981.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931037980.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 喜剧 动作 动画 / 井出安轨 / 三瓶由布子 和泉风花", "title": "杀手青春", "type": "tv", "id": "37315515", "tags": []}, {"comment": "青年·下吕担任家业延续数百年的杀手『用毒人』。\n从事见不得光的工作，又不擅长跟女性交流，他认为自己不该结婚。\n然而，为了延续『用毒人』的血统，老家宣布将强制要求他的妹妹生下接班人。\n此时，下吕遇见了原本是工作目标的婚姻骗子‧城崎…？\n「那样的提案〈求婚〉，还是头一遭。」\n把婚姻骗子当成提供建议的人，展开了杀手的婚姻活动！", "rating": {"count": 213, "max": 10, "star_count": 3.5, "value": 7.4}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.do