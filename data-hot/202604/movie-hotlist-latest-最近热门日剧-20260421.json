om/view/photo/m/public/p2931677646.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931677645.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 悬疑 犯罪 / 山本刚义 坂上卓哉 川口结 / 冈田将生 染谷将太", "title": "田锁兄弟", "type": "tv", "id": "38210087", "tags": []}, {"comment": "《孤独的美食家》 第11季宣布回归，定档4月3日开播。\n这也是继2022年10月第10季播出以来，该系列时隔三年半再次推出新一季。\n面对这次回归，松重丰表示，在经历了10季剧集、衍生剧以及电影版后，本来是深成身退的最佳时机，但由于种种缘由决定继续出演。他感叹顺应命运、吃完眼前的料理也是人生。", "rating": {"count": 518, "max": 10, "star_count": 4.5, "value": 8.7}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2930746515.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2930746515.jpg"}, "honor_infos": [{"kind": "tv", "uri": "douban://douban.com/subject_collection/tv_global_best_weekly?type=rank&category=movie&rank_type=weekly", "rank": 9, "title": "一周全球口碑剧集榜"}], "uri": "douban://douban.com/tv/38359420", "episodes_info": "", "photos": ["https://img9.doubanio.com/view/photo/m/public/p2931334915.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931334914.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931334913.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931334912.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 / 北畑龙一 井川尊史 北尾賢人 中山大晖 田尾彩美 / 松重丰 户田菜穗", "title": "孤独的美食家 第十一季", "type": "tv", "id": "38359420", "tags": []}, {"comment": "总是身处人群中心、备受欢迎，却又带着几分冷淡的青山翔太（井内悠阳 饰），以及成绩优异、独来独往的一匹狼千川阳（阿久根温世 饰）。彼此不知道对方的班级和名字，却唯独记得那张脸。性格截然相反的两人，某天在通往天台的楼梯转角相遇了。在喧嚣仿佛被隔绝、只属于两人的空间里，他们开始诉说那些无法对人言说的内心。在无人知晓的校园一角，两人共用一只耳机，听着吉他即兴段的旋律，不知不觉间，彼此的心跳渐渐重合——。\n本剧改编自itz的同名原著漫画。", "rating": {"count": 3522, "max": 10, "star_count": 4.0, "value": 7.6}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2929341595.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2929341595.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38221203", "episodes_info": "", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2929904147.jpg", "https://img9.doubanio.com/view/photo/m/public/p2929904146.jpg", "https://img9.doubanio.com/view/photo/m/public/p2929904145.jpg", "https://img3.doubanio.com/view/photo/m/public/p2929904143.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 爱情 同性 / 富田未来 中山佳香 /  井内悠阳 阿久根温世", "title": "对比的我和你", "type": "tv", "id": "38221203", "tags": []}, {"comment": "银座混合酒吧的老板兼跨性别女性野宫露娜（波瑠 饰），以及被婚外情丈夫和任性的孩子困扰、生活充满烦恼的家庭主妇泽辻凉子（麻生久美子 饰），性格迥异却意外搭档的两人，在意外的相遇后踏上寻找凉子大学前男友的大阪之旅。在旅途中，她们不仅卷入了一起谋杀事件，还凭借夏目漱石、太宰治、江户川乱步等经典文学知识，逐步解开谜团，也体悟到了生活的智慧与文学的力量。\n本剧改编自秋吉理香子的同名原著小说。", "rating": {"count": 267, "max": 10, "star_count": 3.5, "value": 7.3}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img3.doubanio.com/view/photo/m_ratio_poster/public/p2931172337.jpg", "normal": "https://img3.doubanio.com/view/photo/s_ratio_poster/public/p2931172337.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38244425", "episodes_info": "", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2931707552.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931636869.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931636867.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931636866.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 喜剧 悬疑 / 丸谷俊平 明石广人 / 波瑠 麻生久美子", "title": "月夜行路：答案在名作中", "type": "tv", "id": "38244425", "tags": []}, {"comment": "本作讲述了一位从成功IT社长转生为面临困境的普通人的男性之“再生＝REBORN”的故事。被称为时代宠儿的新兴IT企业社长根尾光诚，为实现君临业界顶点的野心而一意孤行，为此向创业成员强人所难，并毫不留情地将其舍弃。其在媒体上傲慢言论频出，被视为冷酷无情之人。某日，光诚遭人推下楼梯坠亡。不知为何，他在医院中醒来，发现自己已转生到2012年的世界，化身为与自己相貌一模一样的野本英人。\n作为东京下町萧条关闭的商店街上某家洗衣店的继承人英人，光诚开始了与自己原本性格和生活截然不同的人生。等待着他的是与那些转生前2026年自己曾倚仗财富名声打压过的商店街居民们的生活。光诚决心以手中掌握的“未来14年记忆”为武器，以英人的身份活下去，同时追查2026年杀害自己的真凶。最终，他将站在苦境的平民立场，与那些极致追求财富与名声的上层阶级展开对决。", "rating": {"count": 0, "max": 10, "star_count": 0.0, "value": 0}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2931172095.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2931172095.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38363592", "episodes_info": "", "photos": ["https://img9.doubanio.com/view/photo/m/public/p2931742175.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931742174.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931742173.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931742168.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 悬疑 / 藤田明二 麻生学 二宫崇 / 高桥一生 中村安奈", "title": "再生 ～最后英雄～", "type": "tv", "id": "38363592", "tags": []}, {"comment": "泰坦X并非普通的怪兽，它本身就是一场活生生的灾难。当它巨大的、散发着生物光辉的身躯冲破海面时，整个世界仿佛都屏住了呼吸。在第二季中，泰坦X成为了谜团的核心——一股来自深海的古老力量正在崛起，它的目的不明，它的力量无与伦比，它带来的敬畏与恐惧并存。", "rating": {"count": 1328, "max": 10, "star_count": 3.0, "value": 5.5}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img3.doubanio.com/view/photo/m_ratio_poster/public/p2929569953.jpg", "normal": "https://img3.doubanio.com/view/photo/s_ratio_poster/public/p2929569953.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/36850546", "episodes_info": "", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2929569957.jpg", "https://img3.doubanio.com/view/photo/m/public/p2929019983.jpg", "https://img9.doubanio.com/view/photo/m/public/p2915481396.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930236142.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 美国 日本 / 动作 科幻 冒险 / 库尔特·拉塞尔 怀亚特·罗素", "title": "帝王计划：怪兽遗产 第二季", "type": "tv", "id": "36850546", "tags": []}, {"comment": "性情温和的糕点师早濑陆（松山研一 饰）与妻子夏海、儿子和母亲经营“早濑洋菓子店”。但两年半前妻子失踪，后被发现遇害，早濑却被诬为凶手。与此同时，警视厅刑警仪堂步（铃木亮平 饰）登场——他是不择手段、与黑社会勾结的恶警。面对绝境，早濑决心洗清罪名，重启人生，化身为仪堂追查真凶。夏海的前同事、会计师幸后一香（户田惠梨香 饰）协助他整容改貌，但她的真实意图仍笼罩在谜团之中。", "rating": {"count": 1727, "max": 10, "star_count": 3.0, "value": 6.3}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2929142530.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2929142530.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37434113", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2929104819.jpg", "https://img9.doubanio.com/view/photo/m/public/p2927381026.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931089697.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931089696.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 悬疑 犯罪 / 坪井敏雄 田中健太 元井桃 / 铃木亮平 户田惠梨香", "title": "重启", "type": "tv", "id": "37434113", "tags": []}, {"comment": "本剧以轮椅橄榄球为舞台，讲述性格孤僻的天才宇宙物理学家伍铁文人（堤真一 饰），意外接触到由表姐执教的弱旅“烈焰公牛”。球队长期无胜、矛盾重重，他却把“问题成堆”视为最有趣的难题，夸口要带队夺冠。从不懂规则到深入其中，他在为球队拆解战术与人心困局的过程中，逐渐与队员真心碰撞，也开 始直面自己封闭孤独的人生伤口。这是一段关于羁绊、理解与重生的热血物语。", "rating": {"count": 0, "max": 10, "star_count": 0.0, "value": 0}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2931172186.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2931172186.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37560613", "episodes_info": "", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2929529992.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931762148.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931762147.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931762146.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 运动 / 平野俊一 加藤尚树 伊藤弘晃 / 堤真一 山田裕贵", "title": "礼物", "type": "tv", "id": "37560613", "tags": []}, {"comment": "外表清纯、恋爱经验不算少的梶谷美月，其实一直不擅长接受男性的亲密主动，因此每段感情都难以长久。24岁的她为了获得“普通女孩的幸福”，开始与在知名商社工作的精英篠宫孝之交往。然而两人的第一次亲密接触却出现异样——原来篠宫同样不擅长主动，对亲密关系怀有自卑与心理阴影。看到他羞涩道歉的模样，美月第一次心跳加速，也逐渐意识到自己真正渴望的是成为主动的一方。当两人坦面对方的笨拙与脆弱，一段打破性别刻板印象的恋爱关系悄然萌芽。\n本剧改编自ねじがなめた担同名原著漫画。", "rating": {"count": 1245, "max": 10, "star_count": 4.0, "value": 7.8}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2930652758.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2930652758.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38243036", "episodes_info": "", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2930373693.jpg", "https://img9.doubanio.com/view/photo/m/public/p2930373695.jpg", "https://img9.doubanio.com/view/photo/m/public/p2930373694.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930373692.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 喜剧 爱情 / 八木橋ゆり / 高尾颯斗 志田琥珀", "title": "被女孩子逆推不行吗？", "type": "tv", "id": "38243036", "tags": []}, {"comment": "27岁的土田文菜（杉咲花 饰）是一名已出版两本作品、正在创作第三本小说的作家，平时也在古着店打工。她有一位恋人，但由于过去经历过多段分手与未能实现的感情，她逐渐对“认真喜欢一个人”与“认真面对一段关系”感到畏惧，也不记得自己究竟从什么时候起不能坦率地说出“喜欢”。为了能够好好面对现在的恋人，文菜开始回望自己过去的恋爱。\n剧情描绘文菜曾经历的各种离别与无法成就的恋情，以及在“是否不与重要的人交往更好”“恋爱究竟是什么”之间的反复思索。尽管怀抱着对爱情的恐惧，她仍一步步向前，透过回顾学生时代到现在的恋情，重新寻找自己面对感情的方式。", "rating": {"count": 1677, "max": 10, "star_count": 4.0, "value": 7.6}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2929002635.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2929002635.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37891202", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2929393430.jpg", "https://img9.doubanio.com/view/photo/m/public/p2929818816.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930598143.jpg", "https://img3.doubanio.com/view/photo/m/public/p2928025992.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 爱情 / 今泉力哉 山下敦弘 山田卓司 / 杉咲花 成田凌", "title": "冬日的什么呀，春日的什么呢", "type": "tv", "id": "37891202", "tags": []}, {"comment": "感情不外露的横井凑（吉泽要人 饰），与一切情绪都写在脸上的中乃航（雨宫翔 饰），看似性格相反，却因共同的摄影兴趣而成为挚友，并在大学时期同居。随着凑就业，两人不得不结束同居生活，航这才意识到自己对挚友的感情早已超越友情。数年后，两人以社会人身份重逢——一个“想要继续做朋友”的凑，一个“无论如何都想成为恋人”的航，从彼此的单恋开始，一段暖心又酸涩的双向暗恋喜剧就此展开。\n本剧改编自ろじ的同名原著漫画。", "rating": {"count": 2090, "max": 10, "star_count": 3.5, "value": 7.1}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2928951634.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2928951634.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37660498", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2928951890.jpg", "https://img1.doubanio.com/view/photo/m/public/p2928951889.jpg", "https://img1.doubanio.com/view/photo/m/public/p2928951888.jpg", "https://img3.doubanio.com/view/photo/m/public/p2928951887.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 爱情 同性 / 船曳真珠 野村奈绪 岸田雅喜 / 吉泽要人 雨宫翔", "title": "直到对挚友的“要不要同居”说出“好”", "type": "tv", "id": "37660498", "tags": []}, {"comment": "替背负无法忍受的悲痛的受害者，对逃避法律制裁的加害者进行制裁…", "rating": {"count": 0, "max": 10, "star_count": 0.0, "value": 0}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2931439045.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2931439045.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37315809", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2931636860.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931636859.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931636858.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931636857.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 悬疑 / 白石晃士 / 洼冢洋介 龟梨和也", "title": "外道之歌 第二季", "type": "tv", "id": "37315809", "tags": []}, {"comment": "曾在药企担任王牌销售的吾妻朔太郎（武田航平 饰）因事业瓶颈陷入迷茫，目前处于无职状态；他在偶然中被当年的职场劲敌、如今从事医疗翻译工作的久慈静（涩谷谦人 饰）所救。这对曾在八年前共度过一夜的旧友，在人生的转折点再度重逢，共同面对职场压力、亲人老去以及生活选择，开启了一段苦甜参半的成年爱情故事。", "rating": {"count": 370, "max": 10, "star_count": 3.5, "value": 7.0}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2931028118.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2931028118.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38230920", "episodes_info": "", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2931341292.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931341288.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931219656.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931219655.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 爱情 同性 / 高桥名月 / 武田航平 涩谷谦人", "title": "烟蓝雨后晴", "type": "tv", "id": "38230920", "tags": []}, {"comment": "日本每年有约20万具遗体被归为“死因不明”，真正接受法医学解剖的不足一成。为改变这一现状，厚生劳动省主导成立了拥有调查指示与解剖决定权的法医学专业团队——MEJ（Medical Examiner Japan）。\n从美国归来的天才法医学者水泽真澄（藤冈靛 饰）曾参与大量检死工作。他性格独特却洞察敏锐，不被常识束缚，常以一句“这存在矛盾”追问真相。面对遗体时，他以“LOVED ONE”相称，从细微痕迹中还原逝者生前的时间与被掩盖的事实。\n与他搭档的是MEJ中心长桐生麻帆（泷内公美 饰）。出身母子家庭的她立志通过制度改变社会，却在官僚体系中屡遭挫败。临危受命执掌MEJ的她虽无医学背景，却在一次次案件中直面“死因不明”背后的现实。\n立场与价值观截然不同的两人，在冲突与磨合中携手挑战疑难案件，揭开死亡背后的真相。", "rating": {"count": 0, "max": 10, "star_count": 0.0, "value": 0}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2930949134.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2930949134.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38363163", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2931428518.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931612393.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931612392.jpg", "https://img2.doubanio.com/view/photo/m/public/p2931612391.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 悬疑 / 松山博昭 并木道子 / 藤冈靛 泷内公美", "title": "所爱之人", "type": "tv", "id": "38363163", "tags": []}, {"comment": "故事围绕三位性格迥异的中年好友展开：吉井雄太曾是大型商社王牌业务，如今被调闲职，生活空虚；藤卷肇是中学电影部部长，个性偏执、曾梦想成为导演，但近年来创作热情消退；菊原纪介性格柔弱，继承母亲理发店，照顾渐患失智症的母亲而迷失自我。某天，三人因一则旧城镇的新闻重聚，回忆起1988年的青春岁月与电影研究部往事，发现曾崇拜的女顾问老师神秘失踪。三人重新踏上寻找真相的旅程，在怀旧与现实交错中，找回初心与青春热血。", "rating": {"count": 618, "max": 10, "star_count": 4.0, "value": 7.5}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2928976654.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2928976654.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37862375", "episodes_info": "", "photos": ["https://img9.doubanio.com/view/photo/m/public/p2930223686.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931005256.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931005255.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931005254.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 悬疑 / 森胁智延 / 反町隆史 大森南朋", "title": "弹珠汽水猴子", "type": "tv", "id": "37862375", "tags": []}]}