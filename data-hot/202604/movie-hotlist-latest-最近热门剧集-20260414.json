://img3.doubanio.com/view/photo/m_ratio_poster/public/p2926575497.jpg", "normal": "https://img3.doubanio.com/view/photo/s_ratio_poster/public/p2926575497.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/35897502", "episodes_info": "30集全", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2931081582.jpg", "https://img2.doubanio.com/view/photo/m/public/p2931081581.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931556439.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931556405.jpg"], "vendor_icons": ["https://img2.doubanio.com/f/frodo/8e1b7f8b48804cf759fc411e75d62c5ffd4f8f42/pics/vendors/migu_video.png"], "interest": null, "year": "2026", "card_subtitle": "2026 / 中国大陆 / 爱情 / 刘栋 / 魏哲鸣 郑合惠子", "title": "你是迟来的欢喜", "type": "tv", "id": "35897502", "tags": []}, {"comment": "这是祖国人的世界，完全受制于他反复无常、自大狂妄的意志。休伊、母乳和法兰奇被囚禁在一个“自由营”里。星光努力组织抵抗，对抗压倒性的超级英雄力量。喜美子下落不明。但当OI侠布彻再次出现，准备使用一种能将所有超级英雄从地球上抹去的病毒时，他引发了一连串的事件，这些事件将永远改变世界和世界上的每一个人。", "rating": {"count": 5400, "max": 10, "star_count": 4.5, "value": 9.1}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2930448314.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2930448314.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/36343491", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2930984130.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930984143.jpg", "https://img9.doubanio.com/view/photo/m/public/p2930984144.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931392984.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 美国 / 剧情 喜剧 动作 科幻 犯罪 / 菲利浦·斯格里西亚 莎娜·斯坦 / 卡尔·厄本 杰克·奎德", "title": "黑袍纠察队 第五季", "type": "tv", "id": "36343491", "tags": []}, {"comment": "该剧改编自宝妆成的小说《重生八零：媳妇有点辣》。故事发生在1983年，聚焦于一位现代女性的角色，她在那个充满变革的年代里，背负着“社畜”的标签，却勇敢地踏上了破除谣言与商海弄潮的征程。从一无所有到逐步崛起，她的经历是对逆境中成长的生动诠释。面对生活的重重困难与挑战，女主角凭借不懈的努力和过人的智慧，在商业世界中开辟出一片天地。在这个过程中，她不仅改