 "https://img9.doubanio.com/view/photo/m/public/p2931489406.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931489405.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931393314.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 喜剧 悬疑 / 丸谷俊平 明石广人 / 波瑠 麻生久美子", "title": "月夜行路：答案在名作中", "type": "tv", "id": "38244425", "tags": []}, {"comment": "新人偶像南濑天在团体中长期遭受排挤与欺凌。某天，她意外获得机会，在人气演员宝生千秋主演的电视剧中担任替身，从而与他相遇。起初，千秋只是接受朋友的赌约，抱着玩笑的心态接近天，却渐渐被她的单纯与坚强吸引。随着感情加深，他的爱开始失控，从温柔守护变成强烈占有。爱与执念的界线逐渐崩塌，一场危险而扭曲的恋情悄然展开。\n本剧改编自琴子的同名原著漫画。", "rating": {"count": 897, "max": 10, "star_count": 3.5, "value": 6.7}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2930761330.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2930761330.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38212152", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2930077268.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930077267.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930472083.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930472082.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 爱情 / 酒见显守 佃直樹 塚田芽来 / 风间诺亚 阪口珠美", "title": "乞救之噬，覆食殆尽", "type": "tv", "id": "38212152", "tags": []}, {"comment": "曾在药企担任王牌销售的吾妻朔太郎（武田航平 饰）因事业瓶颈陷入迷茫，目前处于无职状态；他在偶然中被当年的职场劲敌、如今从事医疗翻译工作的久慈静（涩谷谦人 饰）所救。这对曾在八年前共度过一夜的旧友，在人生的转折点再度重逢，共同面对职场压力、亲人老去以及生活选择，开启了一段苦甜参半的成年爱情故事。", "rating": {"count": 0, "max": 10, "star_count": 0.0, "value": 0}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2931028118.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2931028118.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38230920", "episodes_info": "", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2931341292.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931341288.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931219656.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931219655.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 爱情 同性 / 高桥名月 / 武田航平 涩谷谦人", "title": "雾蓝色的雨后晴天", "type": "tv", "id": "38230920", "tags": []}, {"comment": "丈夫去世后独自抚养儿子长大的50岁女性待山凑（永作博美 饰），在儿子独立离家后突然失去生活重心。迷茫之际，她意外进入一所“三个月速成寿司职人”的寿司学院学习。面对严肃古板、对寿司抱有极高自尊的男讲师大江户海弥（松山研一 饰），以及性格各异的同学们，凑在手忙脚乱中重新找回生活节奏，也逐渐思考“为自己而活”的意义。与此同时，她与那位总是与自己意见相左的寿司讲师之间，关系悄然发生变化，一段迟来的成年人恋爱也在不知不觉中展开。", "rating": {"count": 0, "max": 10, "star_count": 0.0, "value": 0}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2931172329.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2931172329.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38231349", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2931052828.jpg", "https://img2.doubanio.com/view/photo/m/public/p2931405401.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931389112.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931389109.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 喜剧 爱情 / 坪井敏雄 冈本伸吾 金子文纪 / 永作博美 松山研一", "title": "为时已是寿司！？", "type": "tv", "id": "38231349", "tags": []}, {"comment": "总是身处人群中心、备受欢迎，却又带着几分冷淡的青山翔太（井内悠阳 饰），以及成绩优异、独来独往的一匹狼千川阳（阿久根温世 饰）。彼此不知道对方的班级和名字，却唯独记得那张脸。性格截然相反的两人，某天在通往天台的楼梯转角相遇了。在喧嚣仿佛被隔绝、只属于两人的空间里，他们开始诉说那些无法对人言说的内心。在无人知晓的校园一角，两人共用一只耳机，听着吉他即兴段的旋律，不知不觉间，彼此的心跳渐渐重合——。\n本剧改编自itz的同名原著漫画。", "rating": {"count": 3162, "max": 10, "star_count": 4.0, "value": 7.6}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2929341595.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2929341595.jpg"}, "honor_in