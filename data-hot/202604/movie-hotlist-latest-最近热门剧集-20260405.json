": 0, "has_linewatch": false, "pic": {"large": "https://img3.doubanio.com/view/photo/m_ratio_poster/public/p2929786343.jpg", "normal": "https://img3.doubanio.com/view/photo/s_ratio_poster/public/p2929786343.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/36544608", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2930997250.jpg", "https://img1.doubanio.com/view/photo/m/public/p2930997249.jpg", "https://img1.doubanio.com/view/photo/m/public/p2929532810.jpg", "https://img9.doubanio.com/view/photo/m/public/p2929532805.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 韩国 / 剧情 爱情 / 郑尚熙 金英载(김영재) / 李圣经 蔡钟协", "title": "在你灿烂的季节", "type": "tv", "id": "36544608", "tags": []}, {"comment": "在惨烈的“涩谷事变”结束后，东京沦为咒灵横行的废墟。五条悟因被封印而被剥夺一切权利，咒术高层趁机下达严酷指令：重启虎杖悠仁的死刑，并指派特级咒术师乙骨忧太担任执行人。\n与此同时，幕后黑手羂索开启了名为“死灭回游”的残酷生存游戏。这场游戏强制全国数以千计的术师在特定结界内互相残杀，旨在以此产生的巨大能量推动人类的“进化”。为了营救被卷入游戏的伏黑惠之姐津美纪，并寻求从内部破解狱门疆、释放五条悟的方法，虎杖与伙伴们毅然踏入充满未知威胁的结界。在混乱的战场上，他们不仅要面对古代术师的跨时空阻击，还要在不断变化的规则中寻找一线生机。", "rating": {"count": 15303, "max": 10, "star_count": 4.5, "value": 8.8}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2928402160.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2928402160.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/36714178", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2926147569.jpg", "https://img1.doubanio.com/view/photo/m/public/p2926147568.jpg", "https://img9.doubanio.com/view/photo/m/public/p2928858425.jpg", "https://img3.doubanio.com/view/photo/m/public/p2928843847.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 动作 动画 奇幻 / 御所园翔太 / 榎木淳弥 内田雄马", "title": "咒术回战 第三季", "type": "tv", "id": "36714178", "tags": []}, {"comment": "上世纪九十年代，青海高原上的玛治县高度依赖农牧业，一度深陷贫困，其周边的无人区博拉木拉富含矿产和野生动物资源，大量的盗猎盗采分子为牟取暴利滥采滥杀。玛治县副县长多杰（胡歌 饰）在县长林培生（李光洁 饰）的支持下成立了巡山队，起初是为脱贫在无人