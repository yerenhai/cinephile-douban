w/photo/m/public/p2931341292.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931341288.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931219656.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931219655.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 爱情 同性 / 高桥名月 / 武田航平 涩谷谦人", "title": "雾蓝色的雨后晴天", "type": "tv", "id": "38230920", "tags": []}, {"comment": "总是身处人群中心、备受欢迎，却又带着几分冷淡的青山翔太（井内悠阳 饰），以及成绩优异、独来独往的一匹狼千川阳（阿久根温世 饰）。彼此不知道对方的班级和名字，却唯独记得那张脸。性格截然相反的两人，某天在通往天台的楼梯转角相遇了。在喧嚣仿佛被隔绝、只属于两人的空间里，他们开始诉说那些无法对人言说的内心。在无人知晓的校园一角，两人共用一只耳机，听着吉他即兴段的旋律，不知不觉间，彼此的心跳渐渐重合——。\n本剧改编自itz的同名原著漫画。", "rating": {"count": 3048, "max": 10, "star_count": 4.0, "value": 7.6}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2929341595.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2929341595.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38221203", "episodes_info": "", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2929904147.jpg", "https://img9.doubanio.com/view/photo/m/public/p2929904146.jpg", "https://img9.doubanio.com/view/photo/m/public/p2929904145.jpg", "https://img3.doubanio.com/view/photo/m/public/p2929904143.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 爱情 同性 / 富田未来 中山佳香 /  井内悠阳 阿久根温世", "title": "对比的我和你", "type": "tv", "id": "38221203", "tags": []}, {"comment": "某电视台收到了一盘来历不明的诡异录像带。不久后，电视台员工又从一家影像制作公司获得了另一段令人不安的影像。而这两段录像之间，竟然存在着某个不可忽视的共同点…", "rating": {"count": 479, "max": 10, "star_count": 4.0, "value": 7.8}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2929744124.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2929744124.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38239563", "episodes_info": "", "photos": ["https://img9.doubanio.com/view/photo/m/public/p2929679676.jpg", "https://img1.doubanio.com/view/photo/m/public/p2929744358.jpg", "https://img3.doubanio.com/view/photo/m/public/p2929744357.jpg", "https://img9.doubanio.com/view/photo/m/public/p2929744356.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 惊悚 恐怖 / 岩泽宏树 / 花衣未菜 梶原翔", "title": "寄往电视台的神秘影像", "type": "tv", "id": "38239563", "tags": []}, {"comment": "新人偶像南濑天在团体中长期遭受排挤与欺凌。某天，她意外获得机会，在人气演员宝生千秋主演的电视剧中担任替身，从而与他相遇。起初，千秋只是接受朋友的赌约，抱着玩笑的心态接近天，却渐渐被她的单纯与坚强吸引。随着感情加深，他的爱开始失控，从温柔守护变成强烈占有。爱与执念的界线逐渐崩塌，一场危险而扭曲的恋情悄然展开。\n本剧改编自琴子的同名原著漫画。", "rating": {"count": 705, "max": 10, "star_count": 3.5, "value": 6.9}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2930761330.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2930761330.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38212152", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2930077268.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930077267.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930472083.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930472082.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 爱情 / 酒见显守 佃直樹 塚田芽来 / 风间诺亚 阪口珠美", "title": "乞救之噬，覆食殆尽", "type": "tv", "id": "38212152", "tags": []}, {"comment": "以演员神木隆之介为核心人物，采用介于真实与虚构之间的“伪纪录片”形式展开叙事，通过多线视角与拼贴式影像结构，营造出真假难辨的观看体验。作品延续“TXQ FICTION”系列一贯的实验性风格，在现实人物与虚构情境之间制造张力，探讨影像、媒体与“真实”之间的关系。", "rating": {"count": 763, "max": 10, "star_count": 3.5, "value": 7.2}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2930179445.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2930179445.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38352225", "episodes_info": "", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2930550782.jpg", "https://img9.doubanio.com/view/photo/m/public/p2930965774.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930965773.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930965772.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 悬疑 / 寺内康太郎 Kôtarô Terauchi 大森時生 皆口大地 近藤亮太", "title": "TXQ FICTION 神木隆之介", "type": "tv", "id": "38352225", "tags": []}, {"comment": "27岁的土田文菜（杉咲花 饰）是一名已出版两本作品、正在创作第三本小说的作家，平时也在古着店打工。她有一位恋人，但由于过去经历过多段分手与未能实现的感情，她逐渐对“认真喜欢一个人”与“认真面对一段关系”感到畏惧，也不记得自己究竟从什么时候起不能坦率地说出“喜欢”。为了能够好好面对现在的恋人，文菜开始回望自己过去的恋爱。\n剧情描绘文菜曾经历的各种离别与无法成就的恋情，以及在“是否不与重要的人交往更好”“恋爱究竟是什么”之间的反复思索。尽管怀抱着对爱情的恐惧，她仍一步步向前，透过回顾学生时代到现在的恋情，重新寻找自己面对感情的方式。", "rating": {"count": 1383, "max": 10, "star_count": 4.0, "value": 7.5}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2929002635.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2929002635.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37891202", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2929393430.jpg", "https://img9.doubanio.com/view/photo/m/public/p2929818816.jpg", "https://img3.doubanio.com/view/photo/m/public/p2928025992.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930598143.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 爱情 / 今泉力哉 山下敦弘 山田卓司 / 杉咲花 成田凌", "title": "冬日的什么呀，春日的什么呢", "type": "tv", "id": "37891202", "tags": []}, {"comment": "性情温和的糕点师早濑陆（松山研一 饰）与妻子夏海、儿子和母亲经营“早濑洋菓子店”。但两年半前妻子失踪，后被发现遇害，早濑却被诬为凶手。与此同时，警视厅刑警仪堂步（铃木亮平 饰）登场——他是不择手段、与黑社会勾结的恶警。面对绝境，早濑决心洗清罪名，重启人生，化身为仪堂追查真凶。夏海的前同事、会计师幸后一香（户田惠梨香 饰）协助他整容改貌，但她的真实意图仍笼罩在谜团之中。", "rating": {"count": 1527, "max": 10, "star_count": 3.0, "value": 6.3}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2929142530.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2929142530.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37434113", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2929104819.jpg", "https://img9.doubanio.com/view/photo/m/public/p2927381026.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931089697.jpg", "https://img9.doubanio.com/view/photo/m/public/p2931089696.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 悬疑 犯罪 / 坪井敏雄 田中健太 元井桃 / 铃木亮平 户田惠梨香", "title": "重启", "type": "tv", "id": "37434113", "tags": []}, {"comment": "外表清纯、恋爱经验不算少的梶谷美月，其实一直不擅长接受男性的亲密主动，因此每段感情都难以长久。24岁的她为了获得“普通女孩的幸福”，开始与在知名商社工作的精英篠宫孝之交往。然而两人的第一次亲密接触却出现异样——原来篠宫同样不擅长主动，对亲密关系怀有自卑与心理阴影。看到他羞涩道歉的模样，美月第一次心跳加速，也逐渐意识到自己真正渴望的是成为主动的一方。当两人坦面对方的笨拙与脆弱，一段打破性别刻板印象的恋爱关系悄然萌芽。\n本剧改编自ねじがなめた担同名原著漫画。", "rating": {"count": 1046, "max": 10, "star_count": 4.0, "value": 7.9}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2930652758.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2930652758.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38243036", "episodes_info": "", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2930373693.jpg", "https://img9.doubanio.com/view/photo/m/public/p2930373695.jpg", "https://img9.doubanio.com/view/photo/m/public/p2930373694.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930373692.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 喜剧 爱情 / 八木橋ゆり / 高尾颯斗 志田琥珀", "title": "被女孩子逆推不行吗？", "type": "tv", "id": "38243036", "tags": []}, {"comment": "感情不外露的横井凑（吉泽要人 饰），与一切情绪都写在脸上的中乃航（雨宫翔 饰），看似性格相反，却因共同的摄影兴趣而成为挚友，并在大学时期同居。随着凑就业，两人不得不结束同居生活，航这才意识到自己对挚友的感情早已超越友情。数年后，两人以社会人身份重逢——一个“想要继续做朋友”的凑，一个“无论如何都想成为恋人”的航，从彼此的单恋开始，一段暖心又酸涩的双向暗恋喜剧就此展开。\n本剧改编自ろじ的同名原著漫画。", "rating": {"count": 1915, "max": 10, "star_count": 3.5, "value": 7.1}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2928951634.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2928951634.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37660498", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2928951890.jpg", "https://img1.doubanio.com/view/photo/m/public/p2928951889.jpg", "https://img1.doubanio.com/view/photo/m/public/p2928951888.jpg", "https://img3.doubanio.com/view/photo/m/public/p2928951887.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 爱情 同性 / 船曳真珠 野村奈绪 岸田雅喜 / 吉泽要人 雨宫翔", "title": "直到对挚友的“要不要同居”说出“好”", "type": "tv", "id": "37660498", "tags": []}, {"comment": "泰坦X并非普通的怪兽，它本身就是一场活生生的灾难。当它巨大的、散发着生物光辉的身躯冲破海面时，整个世界仿佛都屏住了呼吸。在第二季中，泰坦X成为了谜团的核心——一股来自深海的古老力量正在崛起，它的目的不明，它的力量无与伦比，它带来的敬畏与恐惧并存。", "rating": {"count": 1125, "max": 10, "star_count": 3.0, "value": 5.7}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img3.doubanio.com/view/photo/m_ratio_poster/public/p2929569953.jpg", "normal": "https://img3.doubanio.com/view/photo/s_ratio_poster/public/p2929569953.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/36850546", "episodes_info": "", "photos": ["https://img3.doubanio.com/view/photo/m/public/p2929569957.jpg", "https://img3.doubanio.com/view/photo/m/public/p2929019983.jpg", "https://img9.doubanio.com/view/photo/m/public/p2915481396.jpg", "https://img3.doubanio.com/view/photo/m/public/p2930236142.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 美国 日本 / 动作 科幻 冒险 / 库尔特·拉塞尔 怀亚特·罗素", "title": "帝王计划：怪兽遗产 第二季", "type": "tv", "id": "36850546", "tags": []}, {"comment": "故事的舞台再次回到拥有240年历史、京都屈指可数的老字号和菓子店“久乐屋春信”。自“京都人中的京都人”泽藤三八子（常盘贵子 饰）前往巴黎已有八年，新一代女主角三上洛（穗志萌香 饰）自巴黎归来，踏上京都之地。她肩负着一项重大的使命——在这座由外人难以窥见、充满复杂规矩与微妙人情的古都中，面对延续数百年的传统与讲究、以及傲气十足的京都人，洛将与三八子携手直面命运与传承的考验。", "rating": {"count": 314, "max": 10, "star_count": 4.5, "value": 8.7}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2928133175.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2928133175.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37657679", "episodes_info": "", "photos": ["https://img9.doubanio.com/view/photo/m/public/p2929393475.jpg", "https://img3.doubanio.com/view/photo/m/public/p2929393473.jpg", "https://img2.doubanio.com/view/photo/m/public/p2929393471.jpg", "https://img3.doubanio.com/view/photo/m/public/p2929222767.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 纪录片 / 源孝志 / 穗志萌香 常盘贵子", "title": "京都人的私房雅趣 Rouge 继承", "type": "tv", "id": "37657679", "tags": []}, {"comment": "23年前，小学六年级的飞奈淳一（竹内凉真 饰）与关系要好的三名同学，共同把一把卷入事件的手枪埋在樱树下。成年后，淳一成为刑警，却在某起案件中得知：凶器正是当年四人一起埋下的那把枪。更令他震动的是，他以刑警与嫌疑人的身份，与初恋岩本万季子（井上真央 饰）再会。随着调查推进，他逐一与当年的伙伴重逢，被掩埋的真相、背叛与秘密逐渐浮现。过往的“再会”，将彻底改变所有人的人生轨迹。\n本剧改编自横关大的同名原著小说。", "rating": {"count": 2545, "max": 10, "star_count": 3.5, "value": 6.8}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img9.doubanio.com/view/photo/m_ratio_poster/public/p2928087176.jpg", "normal": "https://img9.doubanio.com/view/photo/s_ratio_poster/public/p2928087176.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37855030", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2929051169.jpg", "https://img9.doubanio.com/view/photo/m/public/p2929051166.jpg", "https://img9.doubanio.com/view/photo/m/public/p2928969565.jpg", "https://img9.doubanio.com/view/photo/m/public/p2928969566.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 爱情 悬疑 / 深川荣洋 山本大辅 / 竹内凉真 井上真央", "title": "再会～沉默的真相～", "type": "tv", "id": "37855030", "tags": []}, {"comment": "优衣（芦田爱菜饰）和健健（健二／冈山天音饰）的家位于盛冈市传统商店街，彼此相邻。优衣与在南部铁器店工作的母亲相依为命，健健家则是经营豆腐店的父亲、奶奶与他组成的三人家庭。两人从小在探出房间窗户就能对话的距离下成长。擅长绘画的健健从东京大学毕业后在小设计公司工作。对优衣而言，年长些许的健健是她憧憬已久单向暗恋的对象——温柔体贴、笑容迷人，与他相处总令人幸福洋溢。\n优衣短期大学毕业后进入当地公司工作，却因人手短缺背负过多不熟悉业务。某日她逃离职场，不知不觉来到东京健健的住所。恰逢健健与朋友在家聚会，其中还有位漂亮女性。但健健察觉优衣神色后立即遣散众人，默默倾听她的倾诉。\n在健健家度过一夜后重整心情的优衣正式辞职。恰逢健健老家豆腐店人手不足，她开始在挚爱的豆腐店工作。竟能在健健家工作！清晨早起劳作毫不辛苦，与奶奶一同前往公路驿站及客户处的配送路程也充满欢乐。每日充实幸福的优衣，恰在此时突然迎来健健的归来——他宣布不再回东京，要留在老家经营豆腐店。虽担心发生什么变故，但能每天在同一职场工作让优衣欣喜若狂！从此清晨一同制作豆腐、外出配送，每日相伴的生活就此展开。正当优衣祈愿这份幸福永续之时——？！", "rating": {"count": 358, "max": 10, "star_count": 3.0, "value": 6.3}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img2.doubanio.com/view/photo/m_ratio_poster/public/p2930004891.jpg", "normal": "https://img2.doubanio.com/view/photo/s_ratio_poster/public/p2930004891.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/37517011", "episodes_info": "", "photos": ["https://img1.doubanio.com/view/photo/m/public/p2930386850.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931053217.jpg", "https://img3.doubanio.com/view/photo/m/public/p2931053212.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931053210.jpg"], "vendor_icons": [], "interest": null, "year": "2026", "card_subtitle": "2026 / 日本 / 剧情 爱情 / 津田温子 / 芦田爱菜 冈山天音", "title": "单恋", "type": "tv", "id": "37517011", "tags": []}, {"comment": "本剧改编自北実知あつき的漫画，讲述选择双职工无子女的“DINKs”夫妻关系，因意外怀孕而走向崩溃的故事。\n故事核心围绕选择DINKs生活方式、过着平静生活的金泽浅与丈夫哲也展开。面对周遭“还不生孩子？”“既然结婚了总该要孩子吧”等不请自来的声音，浅感到受伤，而哲也那句“没有孩子也没关系”成为了她心灵的支柱。然而这份平静因意外怀孕而崩塌。曾深信不疑的哲也笑容背后，隐藏着在避孕工具上动手脚的、蓄意而残酷的背叛行为。", "rating": {"count": 0, "max": 10, "star_count": 0.0, "value": 0}, "vendor_count": 0, "has_linewatch": false, "pic": {"large": "https://img1.doubanio.com/view/photo/m_ratio_poster/public/p2930594909.jpg", "normal": "https://img1.doubanio.com/view/photo/s_ratio_poster/public/p2930594909.jpg"}, "honor_infos": [], "uri": "douban://douban.com/tv/38364092", "episodes_info": "", "photos": ["https://img9.doubanio.com/view/photo/m/public/p2930900195.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931389150.jpg", "https://img1.doubanio.com/view/photo/m/public/p2931389149.jpg", "https://img1.doubanio.com/view/photo/m/pu